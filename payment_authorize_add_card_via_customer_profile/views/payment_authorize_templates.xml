<odoo>
    <!-- Payment Methods page for profile creation flow -->
    <template id="payment_methods_via_profile" name="Payment Methods via Profile">
        <t t-call="portal.frontend_layout">
            <t t-set="page_title" t-value="'Add Payment Method'" />
            <t t-set="additional_title"><t t-esc="page_title" /></t>
            <div class="wrap">
                <div class="container">
                    <!-- Portal breadcrumb -->
                    <div class="row">
                        <div class="col-md-6">
                            <ol class="breadcrumb mt8">
                                <li class="breadcrumb-item">
                                    <a href="/my/home">
                                        <i
                                            class="fa fa-home"
                                            role="img"
                                            title="Home"
                                            aria-label="Home"
                                        />
                                    </a>
                                </li>
                                <li class="breadcrumb-item">Add Payment Method</li>
                            </ol>
                        </div>
                        <div class="col-md-6 text-end" t-if="back_url">
                            <a class="btn btn-secondary mt8" t-att-href="back_url">
                                <i class="fa fa-arrow-left" /> Back to Partner
                            </a>
                        </div>
                    </div>

                    <!-- Page content -->
                    <div class="row">
                        <div class="col-lg-7">
                            <div class="alert alert-info mb-3">
                                <i class="fa fa-info-circle" />
                                Add a new payment method for <strong
                                    t-esc="partner.display_name"
                                />.
                                <br />
                                <small class="text-muted">
                                    Card details are securely processed by Authorize.net.
                                    No validation charge will be made.
                                </small>
                            </div>

                            <t
                                t-if="providers"
                                t-call="payment_authorize_add_card_via_customer_profile.manage_via_profile"
                            />
                            <div t-else="" class="alert alert-warning">
                                <p><strong
                                    >No suitable payment provider could be found.</strong></p>
                                <p
                                >Please ensure Authorize.net is configured and enabled.</p>
                            </div>

                            <!-- Existing tokens display -->
                            <t t-if="tokens">
                                <h4 class="mt-4">Existing Payment Methods</h4>
                                <div class="list-group">
                                    <t t-foreach="tokens" t-as="token">
                                        <div
                                            class="list-group-item d-flex justify-content-between align-items-center"
                                        >
                                            <span>
                                                <i
                                                    t-attf-class="fa fa-{{ 'credit-card' if token.authorize_payment_method_type == 'credit_card' else 'bank' }} me-2"
                                                />
                                                <t t-esc="token.display_name" />
                                                <span
                                                    t-if="token.verified"
                                                    class="badge bg-success ms-2"
                                                >
                                                    <i class="fa fa-check" /> Verified
                                                </span>
                                            </span>
                                        </div>
                                    </t>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Manage form for profile creation (adapted from payment.manage) -->
    <template id="manage_via_profile" name="Manage Payment via Profile">
        <form
            name="o_payment_manage"
            class="o_payment_form mt-3 clearfix"
            t-att-data-partner-id="partner_id"
            t-att-data-access-token="access_token"
            t-att-data-landing-route="landing_route"
            t-att-data-profile-creation-route="profile_creation_route"
        >
            <t t-set="provider_count" t-value="len(providers) if providers else 0" />
            <t
                t-set="default_payment_option_id"
                t-value="providers[0].id if provider_count == 1 else None"
            />

            <div class="card">
                <!-- Providers -->
                <t t-foreach="providers" t-as="provider">
                    <div
                        name="o_payment_option_card"
                        class="card-body o_payment_option_card"
                    >
                        <label>
                            <!-- Radio button -->
                            <input
                                name="o_payment_radio"
                                type="radio"
                                t-att-checked="provider.id == default_payment_option_id"
                                t-att-class="'' if provider_count > 1 else 'd-none'"
                                t-att-data-payment-option-id="provider.id"
                                t-att-data-provider="provider.code"
                                data-payment-option-type="provider"
                            />
                            <!-- Provider name -->
                            <span class="payment_option_name">
                                <b t-esc="provider.display_as or provider.name" />
                            </span>
                            <!-- Test Mode badge -->
                            <span
                                t-if="provider.state == 'test'"
                                class="badge rounded-pill text-bg-warning ms-2"
                            >
                                Test Mode
                            </span>
                        </label>
                        <!-- Payment icons -->
                        <t t-call="payment.icon_list" />
                    </div>
                    <!-- Provider inline form (card input) -->
                    <t
                        t-if="provider.sudo()._should_build_inline_form(is_validation=True)"
                    >
                        <div
                            t-attf-id="o_payment_provider_inline_form_{{provider.id}}"
                            name="o_payment_inline_form"
                            class="card-footer d-none"
                        >
                            <t
                                t-set="inline_form_xml_id"
                                t-value="provider.sudo().inline_form_view_id.xml_id"
                            />
                            <div t-if="inline_form_xml_id" class="clearfix">
                                <t t-call="{{inline_form_xml_id}}">
                                    <t t-set="provider_id" t-value="provider.id" />
                                </t>
                            </div>
                        </div>
                    </t>
                </t>
            </div>

            <!-- Save Payment Method button -->
            <div class="float-end mt-2">
                <button
                    name="o_payment_submit_button"
                    type="submit"
                    class="btn btn-primary btn-lg mb8"
                    disabled="true"
                    t-att-data-icon-class="'fa-plus-circle'"
                >
                    <i class="fa fa-plus-circle" />
                    Add Payment Method
                </button>
            </div>
        </form>
    </template>
</odoo>
